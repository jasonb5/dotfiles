{
    "suggest.noselect": false,
    "diagnostic.errorSign": "✘",
    "diagnostic.warningSign": "!",
    "diagnostic.infoSign": "?",
    "diagnostic.checkCurrentLine": true,
    "coc.preferences.formatOnSaveFiletypes": [
        "py",
        "yaml",
        "json",
        "xml"
    ],
    "coc.preferences.hoverTarget": "float",
    "languageserver": {
        "golang": {
            "command": "gopls",
            "rootPatterns": ["go.mod"],
            "filetypes": ["go"]
        }
    },
    "go.goplsOptions": {
        "staticcheck": true
    },
    "python.linting.flake8Enabled": true,
}
