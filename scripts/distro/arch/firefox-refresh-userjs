#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../../.." && pwd)"
PROFILE_NAME="${1:-${DOTFILES_FIREFOX_PROFILE:-dotfiles-arch}}"
PROFILE_ROOT="$ROOT_DIR/config/distro/arch/.mozilla/firefox/$PROFILE_NAME"
OVERRIDES_FILE="$PROFILE_ROOT/user-overrides.js"
OUTPUT_FILE="$PROFILE_ROOT/user.js"
ARKENFOX_USERJS_URL="${ARKENFOX_USERJS_URL:-https://raw.githubusercontent.com/arkenfox/user.js/master/user.js}"

if [[ ! -f "$OVERRIDES_FILE" ]]; then
  printf 'missing overrides file: %s\n' "$OVERRIDES_FILE" >&2
  exit 1
fi

tmpfile="$(mktemp)"
trap 'rm -f -- "$tmpfile"' EXIT

curl -fsSL "$ARKENFOX_USERJS_URL" -o "$tmpfile"

{
  printf '// Generated by scripts/distro/arch/firefox-refresh-userjs\n'
  printf '// Source: %s\n' "$ARKENFOX_USERJS_URL"
  printf '\n'
  cat "$tmpfile"
  printf '\n\n/* Dotfiles overrides appended after the upstream baseline. */\n\n'
  cat "$OVERRIDES_FILE"
} >"$OUTPUT_FILE"

printf 'wrote %s\n' "$OUTPUT_FILE"
