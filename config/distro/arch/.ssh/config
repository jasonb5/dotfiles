Host homelab-*
  User labwarden
  Port 22
  IdentitiesOnly yes
  PreferredAuthentications publickey
  PubkeyAuthentication yes
  ForwardAgent no
  PasswordAuthentication no
  KbdInteractiveAuthentication no
  ServerAliveInterval 30
  ServerAliveCountMax 3

Host homelab-*-admin git.c.angrydonkey.io
  IdentityFile ~/.ssh/id_ed25519_sk_labwarden
  ControlMaster auto
  ControlPersist 4h
  ControlPath ~/.ssh/cm-%r@%h:%p

Host homelab-*-auto
  IdentityFile ~/.ssh/id_ed25519_labwarden_automation
  AddKeysToAgent yes
  ControlMaster no
  ControlPath none

Host homelab-*-recovery
  IdentityFile ~/.ssh/id_ed25519_labwarden_recovery
  BatchMode yes
  ControlMaster no
  ControlPath none

Host homelab-vps-admin homelab-vps-auto homelab-vps-recovery
  HostName 172.245.137.164

Host homelab-triton-admin homelab-triton-auto homelab-triton-recovery triton.angrydonkey.io
  HostName 192.168.55.10

Host homelab-charon-admin
  HostName 192.168.55.20
  User root

Host git.c.angrydonkey.io
  HostName git.c.angrydonkey.io
  User git
