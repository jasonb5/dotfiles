set $mod Mod4
set $term kitty
set $menu fuzzel
set $dotfiles_root /home/titters/devel/personal/dotfiles

set $rose_base #232136
set $rose_surface #2a273f
set $rose_overlay #393552
set $rose_muted #6e6a86
set $rose_subtle #908caa
set $rose_text #e0def4
set $rose_iris #c4a7e7
set $rose_love #eb6f92

font pango:Iosevka Nerd Font 10

default_border pixel 2
default_floating_border pixel 2
include /home/titters/.config/sway/host.conf

gaps inner $gaps_inner
gaps outer $gaps_outer
smart_gaps $smart_gaps_mode

client.focused $rose_iris $rose_iris $rose_text $rose_iris $rose_iris
client.focused_inactive $rose_surface $rose_surface $rose_subtle $rose_surface $rose_surface
client.unfocused $rose_surface $rose_surface $rose_muted $rose_surface $rose_surface
client.urgent $rose_love $rose_love $rose_text $rose_love $rose_love
client.placeholder $rose_overlay $rose_overlay $rose_text $rose_overlay $rose_overlay

floating_modifier $mod normal

bindsym $mod+Return exec $term
bindsym $mod+d exec $menu
bindsym $mod+f floating toggle
bindsym $mod+Shift+f fullscreen toggle
bindsym $mod+Shift+q kill
bindsym $mod+Shift+e exec swaymsg exit
bindsym $mod+Shift+c reload

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9

bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+m exec sh -c '"$dotfiles_root/scripts/distro/arch/sway-toggle-hidden-workspace.sh"'

bindsym Print exec grim -g "$(slurp)" - | wl-copy
bindsym $mod+Shift+n exec swaync-client -t -sw
bindsym $mod+Shift+w exec sh -c '"$dotfiles_root/scripts/distro/arch/wallpaper-picker.sh"'

include ~/.config/sway/idle.conf

for_window [shell="xwayland"] title_format "[X11] %title"

exec_always sh -c 'export DOTFILES_ROOT="$dotfiles_root" MOZ_ENABLE_WAYLAND=1 QT_QPA_PLATFORM=wayland QT_WAYLAND_DISABLE_WINDOWDECORATION=1 ELECTRON_OZONE_PLATFORM_HINT=auto OZONE_PLATFORM_HINT=auto; dbus-update-activation-environment --systemd --all; systemctl --user import-environment DOTFILES_ROOT MOZ_ENABLE_WAYLAND QT_QPA_PLATFORM QT_WAYLAND_DISABLE_WINDOWDECORATION ELECTRON_OZONE_PLATFORM_HINT OZONE_PLATFORM_HINT'
exec_always swaymsg "smart_gaps $smart_gaps_mode; gaps inner all set $gaps_inner; gaps outer all set $gaps_outer"
exec_always sh -c '"$dotfiles_root/scripts/distro/arch/wallpaper.sh"'
exec_always sh -c 'pkill -x polkit-gnome-authentication-agent-1 >/dev/null 2>&1 || true; /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1'
exec_always sh -c 'pkill -x ironbar >/dev/null 2>&1 || true; DOTFILES_ROOT="$dotfiles_root" ironbar'
exec_always sh -c 'pkill -x swaync >/dev/null 2>&1 || true; swaync'
exec_always sh -c 'pkill -x swayidle >/dev/null 2>&1 || true; swayidle -w timeout $swayidle_lock_timeout "swaylock -f -c 232136" timeout $swayidle_suspend_timeout "systemctl suspend" before-sleep "swaylock -f -c 232136"'
